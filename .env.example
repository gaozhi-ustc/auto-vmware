# auto-vmware 配置示例
# 复制为 .env 并填入真实值；.env 必须被 git 忽略，不得提交。

# Ubuntu ISO 路径
AUTO_VMWARE_ISO_PATH=/DATA/downloads/ubuntu-22.04.5-desktop-amd64.iso

# FlClash / Chrome / Clash 配置路径
AUTO_VMWARE_FLCLASH_DEB=/DATA/downloads/FlClash-0.8.93-linux-amd64.deb
AUTO_VMWARE_CHROME_DEB=/DATA/downloads/google-chrome-stable_current_amd64.deb
AUTO_VMWARE_CLASH_CONFIG=/DATA/downloads/gaozhi_new.yaml

# 虚拟机父目录
AUTO_VMWARE_VM_BASE_DIR=/DATA/vmware
